<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
  document.documentElement.classList.add('aos-ready');
  AOS.init({
    duration: 700,
    easing: 'ease-out-cubic',
    once: true,
    offset: 80,
    disable: function() { return window.matchMedia('(prefers-reduced-motion: reduce)').matches; }
  });

  // Light parallax for hero decorative elements
  (function(){
    const hero = document.querySelector('#top');
    if (!hero) return;
    const items = hero.querySelectorAll('.nm-float, .nm-float-2');
    let raf = null;
    window.addEventListener('scroll', function(){
      if (raf) return;
      raf = requestAnimationFrame(function(){
        const y = window.scrollY;
        items.forEach((el, i) => {
          el.style.transform = 'translateY(' + (y * (0.08 + i*0.04)) + 'px)';
        });
        raf = null;
      });
    }, { passive: true });
  })();
 
    let lastScrollTop = 0;
const header = document.getElementById('header');

window.addEventListener('scroll', function() {
    // Получаем текущую позицию скролла
    let scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    if (scrollTop > lastScrollTop && scrollTop > 100) {
        // Если скроллим вниз и отошли от верха на 100px — скрываем
        header.classList.add('header-hidden');
    } else {
        // Если скроллим вверх — показываем
        header.classList.remove('header-hidden');
    }

    // Запоминаем позицию для следующего шага
    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
}, { passive: true });

    
</script>
