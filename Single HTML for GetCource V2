/* ───────── Scroll-driven Video Section ───────── */
const ScrollVideoSection = () => {
  const sectionRef = useRef<HTMLDivElement>(null);
  const frameRef = useRef<HTMLDivElement>(null);

  const handleScroll = useCallback(() => {
    const section = sectionRef.current;
    const frame = frameRef.current;
    if (!section || !frame) return;

    const rect = section.getBoundingClientRect();
    const sectionHeight = section.offsetHeight;
    const scrolled = -rect.top;
    const progress = Math.max(0, Math.min(1, scrolled / (sectionHeight - window.innerHeight)));

    const minW = 60;
    const maxW = 100;
    const w = minW + (maxW - minW) * progress;
    const radius = 20 * (1 - progress);

    // Desktop: start at 75% height (square), mobile: full
    const isMobile = window.innerWidth < 768;
    const vwInPx = window.innerWidth * minW / 100;
    const startH = isMobile
      ? (vwInPx / window.innerHeight) * 100
      : Math.min((vwInPx / window.innerHeight) * 100, 75);
    const h = startH + (100 - startH) * progress;

    frame.style.width = `${w}vw`;
    frame.style.height = `${h}vh`;
    frame.style.borderRadius = `${radius}px`;
  }, []);

  useEffect(() => {
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
    return () => window.removeEventListener('scroll', handleScroll);
  }, [handleScroll]);

  return (
    <div ref={sectionRef} className="nm-video-section nm-paper">
      <div className="nm-video-sticky">
        <div ref={frameRef} className="nm-video-frame" style={{ width: '60vw', height: '60vw' }}>
          <video
            src="https://fs05.gcfiles.net/fileservice/file/download/a/17088/sc/194/h/9c50f3f344629f86ab5a24af5bad3256.mp4"
            autoPlay
            muted
            loop
            playsInline
          />
        </div>
      </div>
    </div>
  );
};

/* ───────── Hide-on-scroll Header Hook ───────── */
const useHideOnScroll = () => {
  const [visible, setVisible] = useState(true);
  const lastScrollY = useRef(0);

  useEffect(() => {
    const onScroll = () => {
      const currentY = window.scrollY;
      if (currentY < 60) {
        setVisible(true);
      } else if (currentY > lastScrollY.current) {
        setVisible(false);
      } else {
        setVisible(true);
      }
      lastScrollY.current = currentY;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    return () => window.removeEventListener('scroll', onScroll);
  }, []);

  return visible;
};

